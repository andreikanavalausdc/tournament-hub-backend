{
  "name": "tournament-hub-backend",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"shared/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,shared}/**/*.ts\" --fix",
    "docker:up": "docker-compose --env-file .env -f ./docker-compose.yml -p tournament-hub up -d --build",
    "typeorm": "ts-node -r tsconfig-paths/register --files ./node_modules/typeorm/cli.js",
    "mig:create": "npm run typeorm migration:create shared/migrations/$npm_config_name",
    "mig:create-win": "npm run typeorm migration:create shared/migrations/%npm_config_name%",
    "mig:generate": "npm run typeorm migration:generate -- -d shared/config/orm-migration.config.ts -p shared/migrations/$npm_config_name",
    "mig:generate-win": "npm run typeorm migration:generate -- -d shared/config/orm-migration.config.ts -p shared/migrations/%npm_config_name%",
    "mig:show": "npm run typeorm migration:show -- -d shared/config/orm-migration.config.ts",
    "mig:run": "npm run typeorm migration:run -- -d shared/config/orm-migration.config.ts",
    "mig:revert": "npm run typeorm migration:revert -- -d shared/config/orm-migration.config.ts"
  },
  "dependencies": {
    "@nestjs-modules/ioredis": "^2.2.1",
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/swagger": "^11.2.7",
    "@nestjs/typeorm": "^11.0.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.1",
    "env-var": "^7.5.0",
    "ioredis": "^5.10.1",
    "nestjs-i18n": "^10.6.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.19",
    "@nestjs/schematics": "^11.0.10",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.1"
  }
}
