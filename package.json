{
  "name": "tournament-hub-backend",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"shared/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,shared}/**/*.ts\" --fix",
    "docker:up": "docker-compose --env-file ./.env -f ./docker-compose.yml -p tournament-hub up -d --build",
    "typeorm": "ts-node -r tsconfig-paths/register --files ./node_modules/typeorm/cli.js",
    "mig:create": "npm run typeorm migration:create shared/migrations/$npm_config_name",
    "mig:generate": "npm run typeorm migration:generate -- -d shared/config/orm-migration.config.ts -p shared/migrations/$npm_config_name",
    "mig:show": "npm run typeorm migration:show -- -d shared/config/orm-migration.config.ts",
    "mig:run": "npm run typeorm migration:run -- -d shared/config/orm-migration.config.ts",
    "mig:revert": "npm run typeorm migration:revert -- -d shared/config/orm-migration.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "dotenv": "^17.3.1",
    "env-var": "^7.5.0",
    "nestjs-i18n": "^10.6.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^16.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
